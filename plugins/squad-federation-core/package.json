{
  "name": "squad-federation-core-scripts",
  "version": "0.1.0",
  "type": "module",
  "description": "Federated squad orchestration scripts — domain-agnostic machinery for multi-squad workflows",
  "scripts": {
    "onboard": "tsx scripts/onboard.ts",
    "launch": "tsx scripts/launch.ts",
    "monitor": "tsx scripts/monitor.ts",
    "learn": "tsx scripts/learn.ts",
    "query": "tsx scripts/query-learnings.ts",
    "sync-skills": "tsx scripts/sync-skills.ts",
    "sweep": "tsx scripts/sweep-learnings.ts",
    "graduate": "tsx scripts/graduate-learning.ts",
    "dashboard": "tsx scripts/dashboard.ts",
    "heartbeat": "tsx scripts/meta-heartbeat.ts",
    "setup": "tsx scripts/setup.ts",
    "offboard": "tsx scripts/offboard.ts",
    "test": "vitest run --config scripts/vitest.config.ts",
    "test:watch": "vitest --config scripts/vitest.config.ts",
    "test:coverage": "vitest run --config scripts/vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@bradygaster/squad-sdk": "latest",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"

  }
}
