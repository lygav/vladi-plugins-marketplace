{
  "id": "coding",
  "name": "Coding",
  "description": "Teams that write code and open pull requests",
  "version": "0.3.2",
  "coreCompatibility": ">=0.2.0",
  "states": {
    "lifecycle": [
      "preparing",
      "implementing",
      "testing",
      "pr-open",
      "pr-review",
      "pr-approved",
      "merged",
      "complete",
      "failed"
    ],
    "terminal": ["complete", "failed"],
    "pauseable": []
  },
  "monitor": {
    "display": {
      "sectionTitle": "Coding Teams",
      "stateProgressFormat": "step",
      "groupByArchetype": true,
      "archetypeEmoji": "💻"
    }
  }
}
